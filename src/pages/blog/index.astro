---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
---
<BaseLayout title="Blog — Xianglong Fu">
  <header class="pt-24 pb-6">
    <div class="font-mono text-[13px] font-bold text-blue tracking-wide">// WRITING</div>
    <h1 class="font-display font-bold text-ink text-[clamp(34px,5vw,52px)] mt-2 tracking-tight">Blog</h1>
    <p class="max-w-[58ch] mt-4 text-body">Notes on building ML systems from scratch — the math, the search, the deploys.</p>
  </header>

  <section class="pb-8 flex flex-col">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}/`} class="group grid grid-cols-1 md:grid-cols-[130px_1fr_auto] gap-x-6 gap-y-1 items-baseline py-6 border-t border-line rounded-lg hover:bg-[#F8FAFC] hover:px-4 transition-all">
        <span class="font-mono text-[13px] text-muted">{fmt(post.data.pubDate)}</span>
        <span>
          <span class="font-display font-semibold text-ink text-[19px] group-hover:text-blue transition-colors block">{post.data.title}</span>
          <span class="text-sm text-body mt-1 block max-w-[62ch]">{post.data.description}</span>
        </span>
        {post.data.tags[0] && <span class="font-mono text-[11px] text-body border border-line rounded-full px-3 py-1 whitespace-nowrap justify-self-start md:justify-self-auto">{post.data.tags[0]}</span>}
      </a>
    ))}
    {posts.length === 0 && <p class="text-muted font-mono text-sm py-10">No posts yet. Write your first one at <span class="text-blue">/admin</span>.</p>}
  </section>
</BaseLayout>
