---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured).slice(0, 2);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });

// Education — edit these entries directly.
const education = [
  {
    degree: 'Master of Data Science',
    school: 'University of Melbourne',
    location: 'Melbourne, Australia',
    period: '2025 — 2026',
    note: 'Expected Dec 2026. Coursework across machine learning, statistical modelling, and high-performance computing.',
  },
  {
    degree: 'B.Sc. in Applied Statistics',
    school: 'Western University',
    location: 'London, Ontario, Canada',
    period: '20XX — 20XX',
    note: 'Foundations in probability, statistical inference, and data analysis.',
  },
];
---
<BaseLayout>
  <!-- hero -->
  <header id="about" class="pt-24 pb-16">
    <div class="font-mono font-bold text-ink text-[clamp(24px,3.5vw,34px)]">
      Hello! <span class="inline-block origin-[70%_70%] animate-[wave_2.4s_ease-in-out_infinite]">👋</span>
    </div>
    <h1 class="font-mono font-bold text-ink leading-[1.05] tracking-tight mt-2 text-[clamp(40px,7.5vw,84px)]">
      I'm <span class="font-display font-extrabold text-blue tracking-tight">Xianglong&nbsp;Fu</span>
    </h1>
    <div class="font-mono text-body mt-5 text-[clamp(15px,2vw,18px)]">Data Scientist · ML Engineer</div>
    <p class="max-w-[54ch] mt-6 text-[17px] text-body">
      I build neural networks and game-playing AI <strong class="text-ink font-semibold">from scratch</strong>
      — backprop in raw NumPy, search trees by hand. Master of Data Science at the University of Melbourne.
    </p>

    <div class="flex flex-wrap gap-3.5 mt-8">
      <a href="/projects" class="font-mono text-sm font-medium px-5 py-3 rounded-lg bg-blue text-white border-[1.5px] border-blue hover:bg-blue-deep hover:border-blue-deep transition-all hover:-translate-y-0.5">View projects</a>
      <a href="/blog" class="font-mono text-sm font-medium px-5 py-3 rounded-lg text-ink border-[1.5px] border-ink hover:bg-blue-soft hover:border-blue hover:text-blue transition-all hover:-translate-y-0.5">Read the blog</a>
    </div>

    <div class="flex gap-4 mt-10">
      <a href="https://github.com/MichaelFu627" target="_blank" rel="noopener" aria-label="GitHub" class="w-10 h-10 grid place-items-center rounded-lg border border-line text-ink hover:text-blue hover:border-blue hover:bg-blue-soft transition-all hover:-translate-y-0.5">
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-[18px] h-[18px]"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
      </a>
      <a href="https://huggingface.co/MichaelFu627" target="_blank" rel="noopener" aria-label="Hugging Face" class="w-10 h-10 grid place-items-center rounded-lg border border-line text-ink hover:text-blue hover:border-blue hover:bg-blue-soft transition-all hover:-translate-y-0.5">
        <span class="text-[17px]">🤗</span>
      </a>
      <a href="mailto:your-email@example.com" aria-label="Email" class="w-10 h-10 grid place-items-center rounded-lg border border-line text-ink hover:text-blue hover:border-blue hover:bg-blue-soft transition-all hover:-translate-y-0.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px]"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
      </a>
    </div>
  </header>

  <!-- featured projects -->
  {featured.length > 0 && (
    <section class="pt-12">
      <div class="font-mono text-[13px] font-bold text-blue tracking-wide">// FEATURED</div>
      <h2 class="font-display font-bold text-ink text-[clamp(26px,3.4vw,34px)] mt-2 mb-2 tracking-tight">
        Selected projects <span class="font-mono font-normal text-muted">{'{ }'}</span>
      </h2>
      {featured.map(async (p) => {
        const { Content } = await p.render();
        return (
          <ProjectCard title={p.data.title} venue={p.data.venue} image={p.data.image} authors={p.data.authors} links={p.data.links}>
            <Content />
          </ProjectCard>
        );
      })}
      <a href="/projects" class="inline-flex items-center gap-2 font-mono text-sm text-blue font-medium mt-7 hover:gap-3 transition-all">All projects →</a>
    </section>
  )}

  <!-- education -->
  <section id="education" class="pt-16">
    <div class="font-mono text-[13px] font-bold text-blue tracking-wide">// EDUCATION</div>
    <h2 class="font-display font-bold text-ink text-[clamp(26px,3.4vw,34px)] mt-2 mb-6 tracking-tight">
      Education <span class="font-mono font-normal text-muted">&#x1F393;</span>
    </h2>
    <div class="flex flex-col">
      {education.map((e) => (
        <div class="grid grid-cols-1 md:grid-cols-[150px_1fr] gap-x-6 gap-y-1 py-6 border-t border-line">
          <span class="font-mono text-[13px] text-muted pt-1">{e.period}</span>
          <div class="border-l-2 border-blue pl-5">
            <h3 class="font-display font-semibold text-ink text-[19px] leading-snug">{e.degree}</h3>
            <p class="text-body text-[15px] mt-0.5">{e.school} · <span class="text-muted">{e.location}</span></p>
            {e.note && <p class="text-sm text-body mt-2 max-w-[58ch]">{e.note}</p>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- recent blog -->
  {recentPosts.length > 0 && (
    <section class="pt-16">
      <div class="font-mono text-[13px] font-bold text-blue tracking-wide">// WRITING</div>
      <h2 class="font-display font-bold text-ink text-[clamp(26px,3.4vw,34px)] mt-2 mb-6 tracking-tight">
        From the blog <span class="font-mono font-normal text-muted">&lt;/&gt;</span>
      </h2>
      <div class="flex flex-col">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="group grid grid-cols-1 md:grid-cols-[130px_1fr_auto] gap-x-6 gap-y-1 items-baseline py-5 border-b border-line rounded-lg hover:bg-[#F8FAFC] hover:px-4 transition-all">
            <span class="font-mono text-[13px] text-muted">{fmt(post.data.pubDate)}</span>
            <span>
              <span class="font-display font-semibold text-ink text-[18px] group-hover:text-blue transition-colors block">{post.data.title}</span>
              <span class="text-sm text-body mt-1 block max-w-[60ch]">{post.data.description}</span>
            </span>
            {post.data.tags[0] && <span class="font-mono text-[11px] text-body border border-line rounded-full px-3 py-1 whitespace-nowrap justify-self-start md:justify-self-auto">{post.data.tags[0]}</span>}
          </a>
        ))}
      </div>
      <a href="/blog" class="inline-flex items-center gap-2 font-mono text-sm text-blue font-medium mt-7 hover:gap-3 transition-all">All posts →</a>
    </section>
  )}
</BaseLayout>

<style is:global>
  @keyframes wave {
    0%, 60%, 100% { transform: rotate(0); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
  }
</style>
